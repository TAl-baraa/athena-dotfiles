#!/usr/bin/env python3
import os
import platform
import shutil
import subprocess
import textwrap

CYAN = "\033[96m"
WHITE = "\033[97m"
GRAY = "\033[90m"
GREEN = "\033[92m"
RESET = "\033[0m"

WIDTH = 64
KEY_WIDTH = 10
VALUE_WIDTH = WIDTH - KEY_WIDTH - 7


def cmd(command):
    try:
        return subprocess.check_output(command, shell=True, text=True).strip()
    except Exception:
        return "N/A"


def wrap_value(text):
    return textwrap.wrap(text, VALUE_WIDTH) or [""]


def line(key, value):
    wrapped = wrap_value(value)
    output = []
    output.append(
        f"{CYAN}│{RESET}  {CYAN}{key:<{KEY_WIDTH}}{RESET} {GRAY}:{RESET} {WHITE}{wrapped[0]:<{VALUE_WIDTH}}{CYAN}│{RESET}"
    )
    for part in wrapped[1:]:
        output.append(
            f"{CYAN}│{RESET}  {'':<{KEY_WIDTH}} {GRAY}:{RESET} {WHITE}{part:<{VALUE_WIDTH}}{CYAN}│{RESET}"
        )
    return "\n".join(output)


def section():
    return f"{CYAN}├{'─' * (WIDTH - 2)}┤{RESET}"


def memory():
    try:
        data = {}
        with open("/proc/meminfo") as f:
            for line_ in f:
                k, v = line_.split(":")
                data[k] = int(v.strip().split()[0])
        total = data["MemTotal"]
        available = data["MemAvailable"]
        used = total - available
        percent = int((used / total) * 100)
        return f"{used / 1024 / 1024:.2f} GiB / {total / 1024 / 1024:.2f} GiB ({percent}%)"
    except Exception:
        return "N/A"


def main():
    os_name = cmd("grep '^PRETTY_NAME=' /etc/os-release | cut -d= -f2 | tr -d '\"'")
    kernel = platform.release()
    wm = os.environ.get("XDG_CURRENT_DESKTOP") or cmd("hyprctl version | head -1")
    shell = os.path.basename(os.environ.get("SHELL", "N/A"))
    terminal = os.environ.get("TERM_PROGRAM") or "kitty"
    cpu = cmd("lscpu | grep 'Model name' | sed 's/Model name:[[:space:]]*//'")
    gpu = cmd("lspci | grep -E 'VGA|3D' | sed 's/.*: //' | head -2 | paste -sd ' / ' -")
    uptime = cmd("uptime -p | sed 's/up //'")
    packages = cmd("pacman -Qq | wc -l")

    print(f"{CYAN}╭{'─' * (WIDTH - 2)}╮{RESET}")
    print(f"{CYAN}│{RESET}{'ATHENA MK-I'.center(WIDTH - 2)}{CYAN}│{RESET}")
    print(f"{CYAN}│{RESET}{'SYSTEM STATUS READY'.center(WIDTH - 2)}{CYAN}│{RESET}")
    print(section())
    print(line("OS", os_name))
    print(line("Kernel", kernel))
    print(line("WM", wm))
    print(line("Shell", shell))
    print(line("Terminal", terminal))
    print(section())
    print(line("CPU", cpu))
    print(line("GPU", gpu))
    print(line("Memory", memory()))
    print(line("Uptime", uptime))
    print(line("Packages", f"{packages} pacman"))
    print(f"{CYAN}╰{'─' * (WIDTH - 2)}╯{RESET}")


if __name__ == "__main__":
    main()