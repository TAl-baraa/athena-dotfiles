#!/usr/bin/env bash

PROJECTS="$HOME/Projects"

case "$1" in
    dotfiles)
        codium "$PROJECTS/ATHENA/athena-dotfiles"
        ;;

    jarvis)
        codium "$PROJECTS/Jarvis"
        ;;

    esp)
        codium "$PROJECTS/ESP32"
        ;;

    math)
        codium "$PROJECTS/Math"
        ;;

    mecha)
        codium "$PROJECTS/Mechatronics"
        ;;

    wallpapers)
        thunar "$PROJECTS/ATHENA/athena-dotfiles/wallpapers"
        ;;

    fetch)
        athenafetch
        ;;

    wallpaper)
        shift
        athena-wallpaper "$@"
        ;;
    
    doctor)
        echo "ATHENA Doctor"
        echo

        command -v git >/dev/null && echo "✓ Git"
        command -v docker >/dev/null && echo "✓ Docker"
        command -v codium >/dev/null && echo "✓ VSCodium"
        command -v thunar >/dev/null && echo "✓ Thunar"
        command -v hyprpaper >/dev/null && echo "✓ Hyprpaper"
        command -v athenafetch >/dev/null && echo "✓ ATHENA Fetch"
        command -v athena-wallpaper >/dev/null && echo "✓ Wallpaper Manager"
        ;;

    update)
        sudo pacman -Syu
        ;;

    clean)
        sudo pacman -Sc
        ;;
    
    *)
        clear
        echo "========================================="
        echo "           ATHENA CLI v0.1"
        echo "========================================="
        echo
        echo "Projects"
        echo "  athena dotfiles"
        echo "  athena jarvis"
        echo "  athena esp"
        echo "  athena math"
        echo "  athena mecha"
        echo
        echo "System"
        echo "  athena fetch"
        echo "  athena wallpaper next"
        echo "  athena wallpaper random"
        echo "  athena wallpapers"
        echo
        ;;
esac